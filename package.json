{
  "name": "turbosight",
  "private": true,
  "workspaces": [
    "turbosight-react-overlay",
    "test-app"
  ],
  "scripts": {
    "build": "npm run build -w @thinkgrid/turbosight",
    "build:plugin": "cd turbosight-swc-plugin && cargo build --target wasm32-wasip1 --release",
    "dev": "npm run build -w @thinkgrid/turbosight && npm run dev -w test-app",
    "dev:overlay": "npm run dev -w @thinkgrid/turbosight",
    "dev:app": "npm run dev -w test-app",
    "test": "npm run test -w @thinkgrid/turbosight",
    "typecheck": "npm run typecheck -w @thinkgrid/turbosight --if-present",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^8.0.0",
    "lefthook": "^1.11.0",
    "release-it": "^17.0.0"
  }
}
